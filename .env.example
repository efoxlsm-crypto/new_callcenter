# 이 파일을 복사해서 .env 로 이름을 바꾸고 실제 값을 채우세요.
# .env 파일 자체는 .gitignore에 의해 깃에 올라가지 않습니다.

ANTHROPIC_API_KEY=여기에_발급받은_API_키를_붙여넣으세요 (console.anthropic.com에서 발급)
ANTHROPIC_MODEL=claude-haiku-4-5

# Neon(Postgres) 연결 주소 — neon.tech 대시보드에서 복사한 connection string
DATABASE_URL=postgresql://사용자:비밀번호@호스트/디비이름?sslmode=require

# 헬프데스크 자료(교육스크립트) 재수집 시 이미지 다운로드를 위한 helpdesk.hisco.co.kr 로그인 정보
HISCO_LOGIN_ID=
HISCO_LOGIN_PW=

# 배포된 프론트엔드 주소 (CORS 허용용) — 로컬 개발 중에는 비워두면 localhost만 허용됩니다.
FRONTEND_ORIGIN=
